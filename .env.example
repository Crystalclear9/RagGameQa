APP_NAME=RAG Game QA System
APP_VERSION=1.0.0
DEBUG=False
ENV=dev

API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_game_qa
REDIS_URL=redis://localhost:6379

AI_PROVIDER=mock
RUNTIME_STORAGE_MODE=session

GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

NIM_API_KEY=
NIM_API_BASE=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-70b-instruct
NIM_MAX_TOKENS=2048
NIM_TEMPERATURE=0.2

CLAUDE_API_KEY=
CLAUDE_API_BASE=https://api.anthropic.com
CLAUDE_API_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2000
CLAUDE_TEMPERATURE=0.7

DEFAULT_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_TOKENS=2000
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7
CACHE_ENABLED=False
CACHE_TTL=3600
TIMEOUT_SECONDS=30
MAX_RETRIES=3

RAG_DATA_MODE=database
ENABLE_WEB_RETRIEVAL=True
WEB_RETRIEVAL_TRIGGER_DOC_COUNT=2
WEB_RETRIEVAL_MAX_RESULTS=3
WEB_RETRIEVAL_TIMEOUT_SECONDS=8
ENABLE_BERT_RERANKER=False

KNOWLEDGE_SYNC_SCHEDULER_ENABLED=False
KNOWLEDGE_SYNC_INTERVAL_MINUTES=60
KNOWLEDGE_SYNC_GAMES=wow,lol,genshin
KNOWLEDGE_SYNC_MAX_RESULTS_PER_QUERY=2
KNOWLEDGE_SYNC_INCLUDE_CRAWLER=False
KNOWLEDGE_SYNC_CRAWLER_MAX_PAGES=3

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
JIRA_PRIORITY_LABEL_PREFIX=rag-feedback
